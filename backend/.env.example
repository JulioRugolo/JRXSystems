# =============================================================================
# Variáveis do banco de dados
# =============================================================================
# Opção A — variáveis separadas (padrão calc-impressora-3d / sistema_agenda):
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jrxsystems
DB_USER=root
DB_PASSWORD=

# Opção B — URL única (padrão torres_veiculos / alguns deploys):
# DATABASE_URL=mysql://usuario:senha@127.0.0.1:3306/jrxsystems
#
# Em produção / Railway (plugin MySQL), costuma vir MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT
# — o backend já aceita esses nomes além de DB_*.

# =============================================================================
# Criação do banco e migrations ao subir o servidor
# =============================================================================
# Se true (padrão), tenta CREATE DATABASE IF NOT EXISTS antes de conectar.
# Em Railway, desligue se preferir: DB_AUTO_CREATE=false
DB_AUTO_CREATE=true

# Rodar sequelize-cli db:migrate automaticamente no start (cria/atualiza tabelas).
# No Railway, você pode usar só o "Release Command" e definir SKIP_DB_MIGRATE=true no start para não duplicar.
SKIP_DB_MIGRATE=false

# =============================================================================
# Configurações da aplicação
# =============================================================================
NODE_ENV=development
PORT=3001

# URL pública da API (útil em e-mails ou links futuros)
API_BASE_URL=http://localhost:3001

# CORS: origem do frontend (Vite). Várias origens separadas por vírgula.
# Aceita também FRONTEND_URL / FRONTEND_BASE_URL como nos outros projetos.
FRONTEND_URL=http://localhost:5173
# FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_BASE_URL=http://localhost:5173

# Produção / Railway (exemplo):
# NODE_ENV=production
# PORT=3001
# API_BASE_URL=https://sua-api.railway.app
# FRONTEND_URL=https://seu-site.railway.app
# FRONTEND_ORIGIN=https://seu-site.railway.app

# Opcional — ambiente Railway (documentação / integrações futuras)
# RAILWAY_ENVIRONMENT=production
